[agent]
# openai | openai_compatible | ollama
vendor = openai
base_url = https://api.openai.com/v1
api_key = ${OPENAI_API_KEY}
model = gpt-4o-mini
timeout_sec = 45
temperature = 0.2
system_prompt = 你是 AlphaForge 的量化研究助手，专注策略、回测、因子研究与数据诊断。

[oidc]
client_id = 69ba3eccdb057f1398c742c5
client_secret = ${OIDC_CLIENT_SECRET}
issuer = https://dcp-ultimate.authing.cn/oidc
auth_endpoint = https://dcp-ultimate.authing.cn/oidc/auth
token_endpoint = https://dcp-ultimate.authing.cn/oidc/token
userinfo_endpoint = https://dcp-ultimate.authing.cn/oidc/me
jwks_endpoint = https://dcp-ultimate.authing.cn/oidc/.well-known/jwks.json
redirect_uri = ${OIDC_REDIRECT_URI}
scope = openid profile
